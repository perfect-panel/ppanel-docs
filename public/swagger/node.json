        "dto.Protocol": {
            "type": "object",
            "properties": {
                "accept_proxy_protocol": {
                    "description": "监听器通用兼容字段：是否接收 PROXY protocol；当前节点入站尚未统一启用。",
                    "type": "boolean"
                },
                "allow_insecure": {
                    "description": "TLS 客户端兼容字段：允许跳过证书校验；入站配置通常不消费，不能作为服务端证书配置使用。",
                    "type": "boolean"
                },
                "alpn": {
                    "description": "TLS/HTTP/QUIC 协议通用字段：TLS ALPN 列表，当前主要用于 VLESS、VMess、Trojan、TUIC。",
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "cert_dns_env": {
                    "description": "TLS 协议通用字段：cert_mode=dns 时传给 DNS 服务商的环境变量/凭据配置。",
                    "type": "string"
                },
                "cert_dns_provider": {
                    "description": "TLS 协议通用字段：cert_mode=dns 时使用的 DNS 服务商标识。",
                    "type": "string"
                },
                "cert_mode": {
                    "description": "TLS 协议通用字段：证书来源模式，支持 file、self、http、dns；none 表示不配置证书。",
                    "type": "string"
                },
                "cipher": {
                    "description": "Shadowsocks/SSR 共用字段：Shadowsocks method 或 SSR cipher。",
                    "type": "string"
                },
                "congestion_controller": {
                    "description": "QUIC 协议共用字段：TUIC 的主拥塞控制字段，也是 Naive 的旧字段别名。",
                    "type": "string"
                },
                "disable_sni": {
                    "description": "TLS 客户端兼容字段：禁用 SNI；当前服务端入站不消费。",
                    "type": "boolean"
                },
                "down_mbps": {
                    "description": "Hysteria2 专属字段：服务端下行带宽参数，单位为 Mbps。",
                    "type": "integer"
                },
                "ech_enable": {
                    "description": "TLS ECH 兼容字段：是否启用 Encrypted ClientHello；当前节点入站尚未实现。",
                    "type": "boolean"
                },
                "ech_server_name": {
                    "description": "TLS ECH 兼容字段：ECH 外层 ServerName；当前节点入站尚未实现。",
                    "type": "string"
                },
                "enable": {
                    "description": "通用字段：是否启用该入站协议。",
                    "type": "boolean"
                },
                "encryption": {
                    "description": "VLESS Encryption 专属字段：加密套件，如 none、mlkem768x25519plus。",
                    "type": "string"
                },
                "encryption_client_padding": {
                    "description": "VLESS Encryption 客户端信息字段：客户端方向 padding 规则，用于订阅输出。",
                    "type": "string"
                },
                "encryption_mode": {
                    "description": "VLESS Encryption 专属字段：密钥封装模式，如 native、xorpub、random。",
                    "type": "string"
                },
                "encryption_password": {
                    "description": "VLESS Encryption 客户端信息字段：1-RTT/派生认证密码，用于订阅输出。",
                    "type": "string"
                },
                "encryption_private_key": {
                    "description": "VLESS Encryption 服务端专属字段：ML-KEM/X25519 私钥材料。",
                    "type": "string"
                },
                "encryption_rtt": {
                    "description": "VLESS Encryption 专属字段：握手往返模式，取值 0rtt 或 1rtt。",
                    "type": "string"
                },
                "encryption_server_padding": {
                    "description": "VLESS Encryption 服务端专属字段：服务端方向 padding 规则。",
                    "type": "string"
                },
                "encryption_ticket": {
                    "description": "VLESS Encryption 服务端专属字段：0-RTT ticket。",
                    "type": "string"
                },
                "fingerprint": {
                    "description": "TLS 客户端兼容字段：uTLS 指纹；当前节点入站不消费，仅为出站/旧配置兼容保留。",
                    "type": "string"
                },
                "flow": {
                    "description": "VLESS 专属字段：XTLS Vision 流控模式，当前有效值为 xtls-rprx-vision。",
                    "type": "string"
                },
                "heartbeat": {
                    "description": "TUIC 专属字段：连接心跳间隔，单位为秒；0 使用节点默认值。",
                    "type": "integer"
                },
                "hop_interval": {
                    "description": "Hysteria2/TUIC 类 QUIC 协议字段：端口跳跃时间间隔；当前节点入站尚未启用该能力。",
                    "type": "integer"
                },
                "hop_ports": {
                    "description": "Hysteria2/TUIC 类 QUIC 协议字段：端口跳跃范围；当前节点入站尚未启用该能力。",
                    "type": "string"
                },
                "host": {
                    "description": "VLESS/VMess/Trojan 传输字段：WebSocket、HTTPUpgrade 或 XHTTP 的 Host。",
                    "type": "string"
                },
                "mode": {
                    "description": "Snell 专属字段：Snell v6 的工作模式；其他协议不应设置。",
                    "type": "string"
                },
                "multiplex": {
                    "description": "协议无关能力字段：多路复用级别（off、low、medium、high），适用于支持 mux 的流协议。",
                    "type": "string"
                },
                "network": {
                    "description": "监听网络通用字段：选择 tcp、udp 或 both；Naive、Mieru、SSR、TUIC、Snell 等协议会按各自能力校验。",
                    "type": "string"
                },
                "obfs": {
                    "description": "混淆协议共用字段：Hysteria2 的 Salamander、Snell v5 的 obfs、SSR 的 obfs 方法。",
                    "type": "string"
                },
                "obfs_host": {
                    "description": "旧混淆实现兼容字段：混淆目标 Host；当前节点入站不消费，Shadowsocks 插件应使用 plugin_opts。",
                    "type": "string"
                },
                "obfs_param": {
                    "description": "SSR 专属字段：SSR obfs_param。",
                    "type": "string"
                },
                "obfs_password": {
                    "description": "Hysteria2 专属字段：Salamander 混淆密码，仅在 obfs=salamander 时使用。",
                    "type": "string"
                },
                "obfs_path": {
                    "description": "旧混淆实现兼容字段：混淆请求路径；当前节点入站不消费，Shadowsocks 插件应使用 plugin_opts。",
                    "type": "string"
                },
                "padding_scheme": {
                    "description": "AnyTLS 专属字段：TLS record padding 方案。",
                    "type": "string"
                },
                "path": {
                    "description": "VLESS/VMess/Trojan 传输字段：WebSocket、HTTPUpgrade 或 XHTTP 的请求路径。",
                    "type": "string"
                },
                "plugin": {
                    "description": "Shadowsocks（AEAD/2022）专属字段：入站插件名，如 obfs、v2ray-plugin、shadow-tls、restls。",
                    "type": "string"
                },
                "plugin_opts": {
                    "description": "Shadowsocks（AEAD/2022）专属字段：所选入站插件的结构化参数。"
                },
                "port": {
                    "description": "通用字段：入站监听端口。",
                    "type": "integer"
                },
                "protocol": {
                    "description": "SSR 专属字段：SSR protocol 方法；JSON 名称 protocol 与顶层 type 不同。",
                    "type": "string"
                },
                "protocol_param": {
                    "description": "SSR 专属字段：SSR protocol_param。",
                    "type": "string"
                },
                "quic_congestion_control": {
                    "description": "QUIC 协议共用字段：Naive 的主拥塞控制字段，也是 TUIC 的兼容别名。",
                    "type": "string"
                },
                "ratio": {
                    "description": "面板通用字段：流量计费倍率，默认值为 1；不参与节点协议握手。",
                    "type": "number"
                },
                "reality_private_key": {
                    "description": "VLESS/VMess REALITY 服务端专属字段：服务端 X25519 私钥。",
                    "type": "string"
                },
                "reality_public_key": {
                    "description": "VLESS/VMess REALITY 客户端信息字段：由私钥对应的公钥，主要用于订阅输出。",
                    "type": "string"
                },
                "reality_server_addr": {
                    "description": "VLESS/VMess REALITY 专属字段：REALITY 握手转发目标地址。",
                    "type": "string"
                },
                "reality_server_port": {
                    "description": "VLESS/VMess REALITY 专属字段：REALITY 握手转发目标端口。",
                    "type": "integer"
                },
                "reality_short_id": {
                    "description": "VLESS/VMess REALITY 专属字段：允许客户端使用的 short ID。",
                    "type": "string"
                },
                "reduce_rtt": {
                    "description": "TUIC 专属字段：启用 QUIC 0-RTT，以减少首次握手往返。",
                    "type": "boolean"
                },
                "security": {
                    "description": "TLS/REALITY 协议通用字段：选择 none、tls 或 reality；实际可选值由具体协议限制。",
                    "type": "string"
                },
                "server_key": {
                    "description": "密钥型协议共用字段：Shadowsocks 2022 服务端密钥、SSR 密码或 Snell PSK。",
                    "type": "string"
                },
                "service_name": {
                    "description": "VLESS/VMess/Trojan gRPC 传输专属字段：gRPC service name。",
                    "type": "string"
                },
                "sni": {
                    "description": "TLS 协议通用字段：证书域名及 TLS ServerName；REALITY 也用它作为服务端名称。",
                    "type": "string"
                },
                "traffic_pattern": {
                    "description": "Mieru 专属字段：流量形态/包长分布配置。",
                    "type": "string"
                },
                "transport": {
                    "description": "VLESS/VMess/Trojan 通用传输字段：tcp、ws、httpupgrade、grpc 或 xhttp。",
                    "type": "string"
                },
                "type": {
                    "description": "通用字段：协议类型标识，例如 shadowsocks、vless、vmess、hysteria2、tuic。",
                    "type": "string"
                },
                "udp_relay_mode": {
                    "description": "TUIC/Hysteria 兼容字段：旧实现的 UDP relay 模式；当前节点入站不消费。",
                    "type": "string"
                },
                "uot": {
                    "description": "协议无关能力字段：UDP over TCP 开关，供支持 UoT 的协议使用，并非某一协议专属。",
                    "type": "boolean"
                },
                "uot_version": {
                    "description": "协议无关能力字段：UoT 协议版本，当前支持 1 或 2；0 表示使用默认版本。",
                    "type": "integer"
                },
                "up_mbps": {
                    "description": "Hysteria2 专属字段：服务端上行带宽参数，单位为 Mbps。",
                    "type": "integer"
                },
                "user_hint_is_mandatory": {
                    "description": "Mieru 专属字段：是否强制客户端携带可识别用户的 user hint。",
                    "type": "boolean"
                },
                "version": {
                    "description": "Snell/TUIC 共用字段：Snell 使用协议版本；TUIC 仅接受 5（0 表示默认）。",
                    "type": "integer"
                },
                "xhttp_extra": {
                    "description": "VLESS/VMess/Trojan XHTTP 传输专属字段：XHTTP 扩展路径/参数。",
                    "type": "string"
                },
                "xhttp_mode": {
                    "description": "VLESS/VMess/Trojan XHTTP 传输专属字段：XHTTP 工作模式，如 auto、packet-up、stream-up。",
                    "type": "string"
                }
            }
        },
        "dto.QueryServerConfigResponse": {
            "type": "object",
            "properties": {
                "block": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "dns": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/dto.NodeDNS"
                    }
                },
                "ip_strategy": {
                    "type": "string"
                },
                "outbound": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/dto.NodeOutbound"
                    }
