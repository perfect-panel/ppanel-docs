{
    "consumes": [
        "application/json"
    ],
    "produces": [
        "application/json"
    ],
    "schemes": [
        "http",
        "https"
    ],
    "swagger": "2.0",
    "info": {
        "description": "HTTP API for PPanel's Hertz server. Application errors are returned in the response code and message fields.",
        "title": "PPanel API",
        "contact": {},
        "version": "1.0"
    },
    "paths": {
        "/v1/server/config": {
            "get": {
                "security": [
                    {
                        "NodeSecret": []
                    }
                ],
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "node"
                ],
                "summary": "Get server config",
                "parameters": [
                    {
                        "type": "string",
                        "name": "protocol",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "name": "secret_key",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "name": "server_id",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/dto.GetServerConfigResponse"
                        }
                    }
                }
            }
        },
        "/v1/server/online": {
            "post": {
                "security": [
                    {
                        "NodeSecret": []
                    }
                ],
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "node"
                ],
                "summary": "Push online users",
                "parameters": [
                    {
                        "description": "Request parameters",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/dto.OnlineUsersRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/result.ResponseSuccessBean"
                        }
                    }
                }
            }
        },
        "/v1/server/push": {
            "post": {
                "security": [
                    {
                        "NodeSecret": []
                    }
                ],
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "node"
                ],
                "summary": "Push user Traffic",
                "parameters": [
                    {
                        "description": "Request parameters",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/dto.ServerPushUserTrafficRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/result.ResponseSuccessBean"
                        }
                    }
                }
            }
        },
        "/v1/server/status": {
            "post": {
                "security": [
                    {
                        "NodeSecret": []
                    }
                ],
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "node"
                ],
                "summary": "Push server status",
                "parameters": [
                    {
                        "description": "Request parameters",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/dto.ServerPushStatusRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/result.ResponseSuccessBean"
                        }
                    }
                }
            }
        },
        "/v1/server/user": {
            "get": {
                "security": [
                    {
                        "NodeSecret": []
                    }
                ],
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "node"
                ],
                "summary": "Get user list",
                "parameters": [
                    {
                        "type": "string",
                        "name": "protocol",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "name": "secret_key",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "name": "server_id",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/dto.GetServerUserListResponse"
                        }
                    }
                }
            }
        },
        "/v2/server/{server_id}": {
            "get": {
                "security": [
                    {
                        "NodeSecret": []
                    }
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "node"
                ],
                "summary": "Get Server Protocol Config",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Server ID",
                        "name": "server_id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "array",
                        "items": {
                            "type": "string"
                        },
                        "collectionFormat": "multi",
                        "description": "Protocols to include",
                        "name": "protocols",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/result.ResponseSuccessBean"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "$ref": "#/definitions/dto.QueryServerConfigResponse"
                                        }
                                    }
                                }
                            ]
                        }
                    }
                }
            }
        }
    },
